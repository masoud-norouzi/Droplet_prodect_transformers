\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces Validation of bounding-box to ellipse conversion for frame 48. Green rectangles show the original detection bounding boxes. Red ellipses are axis-aligned footprints fitted inside each bounding box using the midpoint and semi-axis formulas above. The alignment confirms that the detection coordinates use OpenCV-style image coordinates, with $x$ increasing to the right and $y$ increasing downward, and that no transposition, vertical flip, or one-based frame-indexing error is present.}}{12}{figure.caption.3}\protected@file@percent }
\providecommand*\caption@xref[2]{\@setref\relax\@undefined{#1}}
\newlabel{fig:bbox-ellipse-frame48}{{1}{12}{Validation of bounding-box to ellipse conversion for frame 48. Green rectangles show the original detection bounding boxes. Red ellipses are axis-aligned footprints fitted inside each bounding box using the midpoint and semi-axis formulas above. The alignment confirms that the detection coordinates use OpenCV-style image coordinates, with $x$ increasing to the right and $y$ increasing downward, and that no transposition, vertical flip, or one-based frame-indexing error is present}{figure.caption.3}{}}
